function fetchUser(){
    return new Promise(resolve=>{
        setTimeout(()=>{
            resolve({id:1,name:"Krishna"});
        },1500);
    });
}

async function getUser(){
    try{
        const data=await fetchUser();
        console.log(data);
    }
    catch(error){
        console.log(error);

    }
}
getUser();
